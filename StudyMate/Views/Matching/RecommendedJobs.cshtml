@model List<(StudyMate.Models.JobPosting? Job, decimal Score)>
@{ ViewData["Title"] = "Job gợi ý"; }

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Job gợi ý cho bạn</h1>
            <p>AI match theo hồ sơ &amp; môn dạy — ưu tiên job fit cao</p>
        </div>
        <a asp-controller="JobPosting" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-briefcase me-1"></i> Tất cả job
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="surface-card">
            <div class="empty-state">
                <i class="bi bi-stars"></i>
                <p class="mb-2">Chưa có gợi ý.</p>
                <p class="small mb-0">Cập nhật hồ sơ gia sư hoặc đợi job mới được match.</p>
            </div>
        </div>
    }
    else
    {
        <div class="job-feed">
            @foreach (var x in Model)
            {
                if (x.Job == null) { continue; }
                <a asp-controller="JobPosting" asp-action="Details" asp-route-id="@x.Job.Id" class="job-row">
                    <div class="job-row-top">
                        <h2 class="job-row-title">@x.Job.Title</h2>
                        <span class="score-pill"><i class="bi bi-graph-up-arrow"></i> @x.Score.ToString("0.00")</span>
                    </div>
                    <div class="job-row-meta">
                        <span class="tag"><i class="bi bi-book"></i> @(x.Job.Subject?.Name ?? "—")</span>
                        <span class="tag"><i class="bi bi-laptop"></i> @x.Job.TeachingMode</span>
                        <span class="job-row-budget" style="font-size:0.9rem">
                            @(x.Job.BudgetMin?.ToString("N0") ?? "?") – @(x.Job.BudgetMax?.ToString("N0") ?? "?") ₫/h
                        </span>
                    </div>
                </a>
            }
        </div>
    }
</div>
