@model StudyMate.ViewModels.TutorProfile.PublicTutorProfileViewModel
@{
    ViewData["Title"] = Model.Headline ?? Model.FullName;
}

<div class="page-shell">
    <div class="surface-card mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-3 align-items-start">
                @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="Avatar" class="rounded-circle" style="width:88px;height:88px;object-fit:cover" />
                }
                <div class="flex-grow-1">
                    <h1 class="h3 mb-1">@Model.FullName</h1>
                    <p class="text-muted mb-2">@Model.Headline</p>
                    <div class="small text-muted mb-2">
                        ⭐ @Model.AverageRating.ToString("0.0") (@Model.TotalReviews đánh giá)
                        · @Model.YearsOfExperience năm KN
                        · @Model.EducationLevel
                        · @(Model.HourlyRate?.ToString("N0") ?? "—") ₫/giờ
                        · @Model.TeachingMode
                    </div>
                    <div class="mb-2">
                        @foreach (var s in Model.Subjects)
                        {
                            <span class="badge text-bg-light border me-1">@s</span>
                        }
                    </div>
                    @if (Model.ShowContactButton)
                    {
                        <a href="#" class="btn btn-primary btn-sm">Liên hệ / Thuê gia sư</a>
                    }
                    else if (User.Identity?.IsAuthenticated != true)
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm">Đăng nhập để liên hệ</a>
                    }
                </div>
            </div>
            <hr />
            <p style="white-space:pre-wrap">@Model.Bio</p>

            @if (!string.IsNullOrWhiteSpace(Model.VideoIntroUrl))
            {
                var embed = StudyMate.Controllers.TutorProfileController.ToEmbedUrl(Model.VideoIntroUrl);
                <div class="mb-3">
                    <h2 class="h6">Video giới thiệu</h2>
                    @if (embed != null)
                    {
                        <div class="ratio ratio-16x9">
                            <iframe src="@embed" allowfullscreen loading="lazy"></iframe>
                        </div>
                    }
                    else if (Model.VideoIntroUrl.StartsWith("/uploads/", StringComparison.OrdinalIgnoreCase))
                    {
                        <video controls class="w-100 rounded" style="max-height:360px">
                            <source src="@Model.VideoIntroUrl" type="video/mp4" />
                        </video>
                    }
                </div>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="surface-card h-100">
                <div class="card-body">
                    <h2 class="h6">Chứng chỉ đã xác minh</h2>
                    @if (Model.Certificates.Count == 0)
                    {
                        <p class="small text-muted mb-0">Chưa có chứng chỉ công khai.</p>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var c in Model.Certificates)
                            {
                                <li>@c.Title @if (!string.IsNullOrEmpty(c.IssuedBy)) { <span class="text-muted">— @c.IssuedBy</span> }</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="surface-card h-100">
                <div class="card-body">
                    <h2 class="h6">Lịch rảnh</h2>
                    @if (Model.Availabilities.Count == 0)
                    {
                        <p class="small text-muted mb-0">Chưa cập nhật.</p>
                    }
                    else
                    {
                        <ul class="mb-0 small">
                            @foreach (var a in Model.Availabilities)
                            {
                                <li>@a.DayName @a.StartTime.ToString("HH:mm")–@a.EndTime.ToString("HH:mm")</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="surface-card">
                <div class="card-body">
                    <h2 class="h6">Demo lessons</h2>
                    @if (Model.DemoLessons.Count == 0)
                    {
                        <p class="small text-muted mb-0">Chưa có demo.</p>
                    }
                    else
                    {
                        @foreach (var d in Model.DemoLessons)
                        {
                            <div class="mb-2">
                                <strong>@d.Title</strong>
                                @if (!string.IsNullOrWhiteSpace(d.VideoUrl))
                                {
                                    <a href="@d.VideoUrl" class="small ms-2" target="_blank" rel="noopener">Video</a>
                                }
                                <div class="small text-muted">@d.Description</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
