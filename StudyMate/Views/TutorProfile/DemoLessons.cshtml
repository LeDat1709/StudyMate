@model StudyMate.ViewModels.TutorProfile.DemoLessonListViewModel
@{
    ViewData["Title"] = "Demo lessons";
}

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Demo lessons</h1>
            <p>Bài học mẫu cho học viên xem thử.</p>
        </div>
        <a asp-action="MyProfile" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row g-3">
        <div class="col-lg-5">
            <div class="surface-card">
                <div class="card-body">
                    <div class="card-section-title">
                        <i class="bi bi-plus-circle text-primary"></i> Thêm demo
                    </div>
                    <form asp-action="CreateDemoLesson" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="Form.Title" class="form-label"></label>
                            <input asp-for="Form.Title" class="form-control" placeholder="VD: Bài mẫu IELTS Speaking" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Form.Description" class="form-label"></label>
                            <textarea asp-for="Form.Description" class="form-control" rows="3" placeholder="Mô tả ngắn"></textarea>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Form.VideoUrl" class="form-label"></label>
                            <input asp-for="Form.VideoUrl" class="form-control" placeholder="https://..." />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-plus-lg me-1"></i> Thêm
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="surface-card">
                <div class="card-body">
                    <div class="card-section-title">
                        <i class="bi bi-collection-play text-primary"></i> Danh sách demo
                    </div>
                    @if (Model.Items.Count == 0)
                    {
                        <div class="empty-state py-4">
                            <i class="bi bi-play-btn"></i>
                            <p class="mb-0">Chưa có demo lesson.</p>
                        </div>
                    }
                    else
                    {
                        <div class="sm-stack">
                            @foreach (var d in Model.Items)
                            {
                                <div class="sm-stack-item">
                                    <div class="min-w-0">
                                        <div class="item-title">@d.Title</div>
                                        @if (!string.IsNullOrWhiteSpace(d.Description))
                                        {
                                            <p class="small text-muted mb-1">@d.Description</p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(d.VideoUrl))
                                        {
                                            <a href="@d.VideoUrl" target="_blank" rel="noopener" class="small fw-semibold">
                                                <i class="bi bi-box-arrow-up-right me-1"></i>Xem video
                                            </a>
                                        }
                                    </div>
                                    <form asp-action="DeleteDemoLesson" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
