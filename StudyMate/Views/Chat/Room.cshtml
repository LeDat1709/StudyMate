@model List<StudyMate.Models.ChatMessage>
@{
    ViewData["Title"] = "Chat room";
    var me = ViewData["Me"] as string;
    var convId = ViewData["ConversationId"];
}
<div class="page-shell">
  <div class="d-flex justify-content-between mb-2">
    <h1 class="h5 mb-0">Chat với @ViewData["Peer"]</h1>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Danh sách</a>
  </div>
  <div class="surface-card mb-3"><div class="card-body" style="max-height:420px;overflow:auto">
    @foreach (var m in Model) {
      <div class="mb-2 @(m.SenderId==me?"text-end":"")">
        <span class="badge text-bg-light border">@m.Sender?.FullName</span>
        <div>@m.Content</div>
        <div class="small text-muted">@m.SentAt.ToLocalTime().ToString("dd/MM HH:mm")</div>
      </div>
    }
  </div></div>
  <form asp-action="Send" method="post" class="d-flex gap-2">
    @Html.AntiForgeryToken()
    <input type="hidden" name="conversationId" value="@convId" />
    <input name="content" class="form-control" placeholder="Nhắn tin..." required autocomplete="off" />
    <button type="submit" class="btn btn-primary">Gửi</button>
  </form>
</div>
