@model List<StudyMate.Models.ApplicationUser>
@{ ViewData["Title"]="Users"; }
<div class="page-shell"><h1 class="h4">Users</h1>
<table class="table"><thead><tr><th>Name</th><th>Email</th><th>Active</th><th></th></tr></thead><tbody>
@foreach(var u in Model){<tr><td>@u.FullName</td><td>@u.Email</td><td>@u.IsActive</td>
<td><form asp-action="ToggleUserActive" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@u.Id"/><button class="btn btn-sm btn-outline-warning">Toggle</button></form></td></tr>}
</tbody></table></div>
