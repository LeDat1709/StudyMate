@model List<StudyMate.Models.AiLog>
@{ ViewData["Title"] = "AI logs"; }

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>AI logs</h1>
            <p>Lịch sử gọi AI (matching, moderation, assistant)</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Dashboard
        </a>
    </div>

    <div class="sm-table-wrap">
        <table class="table sm-table mb-0">
            <thead>
                <tr>
                    <th>Action</th>
                    <th>Model</th>
                    <th>Input</th>
                    <th>Output</th>
                    <th>At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td><span class="badge badge-soft-primary">@l.Action</span></td>
                        <td class="small">@l.ModelUsed</td>
                        <td class="small text-muted" style="max-width:180px"><div class="text-truncate">@l.InputData</div></td>
                        <td class="small text-muted" style="max-width:180px"><div class="text-truncate">@l.OutputData</div></td>
                        <td class="small text-nowrap">@l.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
