@model List<StudyMate.ViewModels.JobPosting.JobCardViewModel>
@{
    ViewData["Title"] = "Job của tôi";
    var st = ViewData["Status"] as string ?? "All";
    string StatusBadge(string s) => s switch
    {
        "Open" => "badge-soft-success",
        "Closed" => "badge-soft-secondary",
        "Expired" => "badge-soft-warning",
        _ => "badge-soft-primary"
    };
}

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Job của tôi</h1>
            <p>Quản lý yêu cầu thuê gia sư bạn đã đăng</p>
        </div>
        <a class="btn btn-primary btn-sm" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i> Đăng mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>
    }

    <div class="chip-tabs">
        @foreach (var t in new[] { "All", "Open", "Closed", "Expired" })
        {
            <a class="@(st == t ? "active" : "")" asp-action="MyJobs" asp-route-status="@t">@t</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="surface-card">
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p class="mb-2">Chưa có job.</p>
                <a asp-action="Create" class="btn btn-primary btn-sm">Đăng yêu cầu đầu tiên</a>
            </div>
        </div>
    }
    else
    {
        <div class="sm-stack">
            @foreach (var j in Model)
            {
                <div class="sm-stack-item">
                    <div class="min-w-0">
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <a asp-action="Details" asp-route-id="@j.Id" class="item-title">@j.Title</a>
                            <span class="badge @StatusBadge(j.Status)">@j.Status</span>
                        </div>
                        <div class="small text-muted">
                            @j.SubjectName · @j.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                        </div>
                    </div>
                    <div class="d-flex gap-1 flex-wrap">
                        @if (j.Status == "Open")
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@j.Id">Sửa</a>
                            <form asp-action="Close" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@j.Id" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Đóng</button>
                            </form>
                        }
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@j.Id" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Xóa</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
