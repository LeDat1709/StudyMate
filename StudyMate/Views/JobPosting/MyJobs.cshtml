@model List<StudyMate.ViewModels.JobPosting.JobCardViewModel>
@{
  ViewData["Title"] = "Job của tôi";
  var st = ViewData["Status"] as string ?? "All";
}
<div class="page-shell">
  <div class="page-header d-flex justify-content-between"><div><h1>Job của tôi</h1></div>
    <a class="btn btn-primary btn-sm" asp-action="Create">Đăng mới</a></div>
  @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
  @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
  <div class="mb-3">
    @foreach (var t in new[] { "All", "Open", "Closed", "Expired" }) {
      <a class="btn btn-sm me-1 @(st==t?"btn-primary":"btn-outline-secondary")" asp-action="MyJobs" asp-route-status="@t">@t</a>
    }
  </div>
  @if (!Model.Any()) { <p class="text-muted">Chưa có job.</p> }
  <div class="list-group">
    @foreach (var j in Model) {
      <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
          <a asp-action="Details" asp-route-id="@j.Id">@j.Title</a>
          <span class="badge text-bg-light border">@j.Status</span>
          <div class="small text-muted">@j.SubjectName · @j.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
        </div>
        <div class="d-flex gap-1">
          @if (j.Status == "Open") {
            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@j.Id">Sửa</a>
            <form asp-action="Close" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@j.Id" /><button class="btn btn-sm btn-outline-warning">Đóng</button></form>
          }
          <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@j.Id" /><button class="btn btn-sm btn-outline-danger">Xóa</button></form>
        </div>
      </div>
    }
  </div>
</div>
