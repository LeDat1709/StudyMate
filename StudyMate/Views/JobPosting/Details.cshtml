@model StudyMate.ViewModels.JobPosting.JobDetailViewModel
@{ ViewData["Title"] = Model.Title; }
<div class="page-shell">
  @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
  @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
  <div class="surface-card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
      <div>
        <h1 class="h3">@Model.Title</h1>
        <span class="badge text-bg-secondary">@Model.Status</span>
      </div>
      <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Danh sách</a>
    </div>
    <p class="mt-3" style="white-space:pre-wrap">@Model.Description</p>
    <dl class="row small mb-3">
      <dt class="col-sm-3">Môn</dt><dd class="col-sm-9">@Model.SubjectName</dd>
      <dt class="col-sm-3">Trình độ mong muốn</dt><dd class="col-sm-9">@(Model.DesiredLevel ?? "—")</dd>
      <dt class="col-sm-3">Hình thức</dt><dd class="col-sm-9">@Model.TeachingMode</dd>
      <dt class="col-sm-3">Địa điểm</dt><dd class="col-sm-9">@(Model.Address ?? "—")</dd>
      <dt class="col-sm-3">Ngân sách</dt><dd class="col-sm-9">@(Model.BudgetMin?.ToString("N0") ?? "?") – @(Model.BudgetMax?.ToString("N0") ?? "?") ₫</dd>
      <dt class="col-sm-3">Buổi/tuần · phút</dt><dd class="col-sm-9">@(Model.SessionsPerWeek?.ToString() ?? "—") · @(Model.SessionDuration?.ToString() ?? "—")</dd>
      <dt class="col-sm-3">Deadline</dt><dd class="col-sm-9">@(Model.Deadline?.ToString("dd/MM/yyyy") ?? "—")</dd>
      <dt class="col-sm-3">Học viên</dt><dd class="col-sm-9">@Model.StudentName</dd>
    </dl>
    <div class="d-flex flex-wrap gap-2">
      @if (Model.IsOwner && Model.Status == "Open") {
        <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@Model.Id">Sửa</a>
        <a class="btn btn-outline-primary btn-sm" asp-controller="Application" asp-action="ForJob" asp-route-jobId="@Model.Id">Xem apply</a>
        <form asp-action="Close" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><button type="submit" class="btn btn-warning btn-sm">Đóng job</button></form>
        <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa job?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button></form>
      }
      @if (Model.IsOwner) {
        <form asp-controller="Matching" asp-action="Rematch" method="post" class="d-inline">
          @Html.AntiForgeryToken()
          <input type="hidden" name="jobId" value="@Model.Id" />
          <button type="submit" class="btn btn-outline-info btn-sm">Chạy lại AI match</button>
        </form>
      }
      @if (Model.CanApply) {
        <a class="btn btn-primary btn-sm" asp-controller="Application" asp-action="Apply" asp-route-jobId="@Model.Id">Apply ngay</a>
      }
      @if (Model.AlreadyApplied) {
        <span class="btn btn-outline-secondary btn-sm disabled">Đã apply</span>
      }
    </div>
  </div></div>
  @if (Model.MatchedTutors.Any()) {
    <div class="surface-card mt-3"><div class="card-body">
      <h2 class="h6">AI gợi ý gia sư (stub)</h2>
      <ul class="list-group list-group-flush">
        @foreach (var t in Model.MatchedTutors) {
          <li class="list-group-item d-flex justify-content-between">
            <span>#@t.Rank <a asp-controller="TutorProfile" asp-action="Details" asp-route-id="@t.TutorProfileId">@t.FullName</a> — @t.Headline</span>
            <span class="badge text-bg-primary">@t.Score.ToString("0.00")</span>
          </li>
        }
      </ul>
    </div></div>
  }
</div>
