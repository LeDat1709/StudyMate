@model StudyMate.ViewModels.JobPosting.JobDetailViewModel
@{
    ViewData["Title"] = Model.Title;
    string StatusBadge(string s) => s switch
    {
        "Open" => "badge-soft-success",
        "Closed" => "badge-soft-secondary",
        "Expired" => "badge-soft-warning",
        _ => "badge-soft-primary"
    };
    var studentInitial = string.IsNullOrWhiteSpace(Model.StudentName)
        ? "?"
        : Model.StudentName.Trim()[0].ToString().ToUpperInvariant();
    var posted = Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy");
}

<div class="page-shell">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>
    }

    <nav class="breadcrumb-sm" aria-label="breadcrumb">
        <a asp-action="Index">Tìm việc</a>
        <span class="sep">/</span>
        <span>Chi tiết job</span>
    </nav>

    <div class="job-detail-layout">
        @* ── Main content ── *@
        <div class="job-detail-main">
            <div class="job-detail-panel">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge @StatusBadge(Model.Status)">@Model.Status</span>
                    <span class="small text-muted">Đăng @posted</span>
                </div>
                <h1>@Model.Title</h1>
                <div class="meta-row mb-0">
                    @if (!string.IsNullOrWhiteSpace(Model.SubjectName))
                    {
                        <span><i class="bi bi-book"></i> @Model.SubjectName</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.TeachingMode))
                    {
                        <span><i class="bi bi-laptop"></i> @Model.TeachingMode</span>
                    }
                    @if (Model.Deadline.HasValue)
                    {
                        <span><i class="bi bi-calendar-event"></i> Hạn apply @Model.Deadline.Value.ToString("dd/MM/yyyy")</span>
                    }
                </div>
            </div>

            <div class="job-detail-panel">
                <h2>Tóm tắt yêu cầu</h2>
                <div class="job-spec-grid">
                    <div class="job-spec-item">
                        <div class="label">Môn học</div>
                        <div class="value">@(Model.SubjectName ?? "—")</div>
                    </div>
                    <div class="job-spec-item">
                        <div class="label">Trình độ mong muốn</div>
                        <div class="value">@(Model.DesiredLevel ?? "—")</div>
                    </div>
                    <div class="job-spec-item">
                        <div class="label">Hình thức</div>
                        <div class="value">@(Model.TeachingMode ?? "—")</div>
                    </div>
                    <div class="job-spec-item">
                        <div class="label">Địa điểm</div>
                        <div class="value">@(Model.Address ?? (Model.TeachingMode == "Online" ? "Online" : "—"))</div>
                    </div>
                    <div class="job-spec-item">
                        <div class="label">Buổi / tuần</div>
                        <div class="value">@(Model.SessionsPerWeek?.ToString() ?? "—")</div>
                    </div>
                    <div class="job-spec-item">
                        <div class="label">Thời lượng buổi</div>
                        <div class="value">@(Model.SessionDuration.HasValue ? $"{Model.SessionDuration} phút" : "—")</div>
                    </div>
                </div>
            </div>

            <div class="job-detail-panel">
                <h2>Mô tả chi tiết</h2>
                @if (string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="text-muted mb-0">Chưa có mô tả.</p>
                }
                else
                {
                    <div class="job-detail-body">@Model.Description</div>
                }
            </div>

            @if (Model.MatchedTutors.Any())
            {
                <div class="job-detail-panel">
                    <h2><i class="bi bi-stars text-primary me-1"></i> AI gợi ý gia sư</h2>
                    @foreach (var t in Model.MatchedTutors)
                    {
                        <div class="matched-tutor-row">
                            <div class="min-w-0">
                                <span class="small text-muted me-1">#@t.Rank</span>
                                <a asp-controller="TutorProfile" asp-action="Details" asp-route-id="@t.TutorProfileId" class="fw-semibold">
                                    @(t.FullName ?? "Gia sư")
                                </a>
                                @if (!string.IsNullOrWhiteSpace(t.Headline))
                                {
                                    <div class="small text-muted text-truncate">@t.Headline</div>
                                }
                            </div>
                            <span class="score-pill">@t.Score.ToString("0.00")</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* ── Right sticky rail (budget + CTA) ── *@
        <aside class="job-detail-aside">
            <div class="job-aside-card">
                <div class="aside-label">Ngân sách</div>
                <div class="aside-budget">
                    @(Model.BudgetMin?.ToString("N0") ?? "?") – @(Model.BudgetMax?.ToString("N0") ?? "?") ₫
                </div>
                <div class="aside-unit">mỗi giờ</div>

                @if (Model.CanApply)
                {
                    <a class="btn btn-primary" asp-controller="Application" asp-action="Apply" asp-route-jobId="@Model.Id">
                        <i class="bi bi-send me-1"></i> Gửi apply
                    </a>
                }
                else if (Model.AlreadyApplied)
                {
                    <button type="button" class="btn btn-outline-secondary" disabled>Đã apply</button>
                    <a class="btn btn-outline-primary" asp-controller="Application" asp-action="MyApplications">
                        Xem apply của tôi
                    </a>
                }
                else if (Model.IsOwner && Model.Status == "Open")
                {
                    <a class="btn btn-primary" asp-controller="Application" asp-action="ForJob" asp-route-jobId="@Model.Id">
                        <i class="bi bi-people me-1"></i> Xem proposals
                    </a>
                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">
                        <i class="bi bi-pencil me-1"></i> Sửa job
                    </a>
                }
                else if (User.Identity?.IsAuthenticated != true && Model.Status == "Open")
                {
                    <a class="btn btn-primary"
                       asp-controller="Account"
                       asp-action="Login"
                       asp-route-returnUrl="@Url.Action("Details", "JobPosting", new { id = Model.Id })">
                        Đăng nhập để apply
                    </a>
                }
                else if (User.IsInRole("Student") && !Model.IsOwner)
                {
                    <p class="small text-muted mb-0">Chỉ gia sư mới apply được job này.</p>
                }

                @if (Model.IsOwner)
                {
                    <hr class="my-3" style="border-color: var(--sm-line)" />
                    <div class="d-grid gap-2">
                        @if (Model.Status == "Open")
                        {
                            <form asp-action="Close" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-secondary w-100 btn-sm">Đóng job</button>
                            </form>
                        }
                        <form asp-controller="Matching" asp-action="Rematch" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-secondary w-100 btn-sm">
                                <i class="bi bi-arrow-repeat me-1"></i> Chạy lại AI match
                            </button>
                        </form>
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa job này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100 btn-sm">Xóa job</button>
                        </form>
                    </div>
                }
            </div>

            <div class="job-aside-card">
                <div class="aside-label mb-2">Học viên đăng job</div>
                <div class="client-card">
                    @if (!string.IsNullOrWhiteSpace(Model.StudentAvatar))
                    {
                        <img src="@Model.StudentAvatar" class="client-avatar" alt="" />
                    }
                    else
                    {
                        <span class="client-avatar-fallback">@studentInitial</span>
                    }
                    <div>
                        <div class="client-name">@(Model.StudentName ?? "Học viên")</div>
                        <div class="client-meta">Chủ job · StudyMate</div>
                    </div>
                </div>
            </div>

            <a asp-action="Index" class="btn btn-ghost btn-sm w-100">
                <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
            </a>
        </aside>
    </div>
</div>
