@model StudyMate.ViewModels.JobPosting.JobPostingFormViewModel
@{ ViewData["Title"] = "Đăng yêu cầu"; }

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Đăng yêu cầu thuê gia sư</h1>
            <p>Tối đa 5 job đang Open — mô tả rõ để AI match tốt hơn</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Danh sách
        </a>
    </div>

    <div class="surface-card">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <partial name="_Form" model="Model" />
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i> Đăng job
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
