@model List<StudyMate.Models.Notification>
@{ ViewData["Title"]="Thông báo"; }
<div class="page-shell">
  <div class="d-flex justify-content-between mb-3"><h1 class="h4">Thông báo</h1>
  <form asp-action="MarkAllRead" method="post">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-secondary">Đọc tất cả</button></form></div>
  <div class="list-group">@foreach(var n in Model){
    <div class="list-group-item @(n.IsRead?"":"list-group-item-primary")">
      <div class="d-flex justify-content-between"><strong>@n.Title</strong>
      @if(!n.IsRead){<form asp-action="MarkRead" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@n.Id"/><button class="btn btn-sm btn-link">Đánh dấu đọc</button></form>}</div>
      <div class="small">@n.Body</div>
      <div class="small text-muted">@n.Type · @n.CreatedAt.ToLocalTime()</div>
    </div>
  }</div>
</div>
