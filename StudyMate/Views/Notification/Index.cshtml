@model List<StudyMate.Models.Notification>
@{ ViewData["Title"] = "Thông báo"; }

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Thông báo</h1>
            <p>Cập nhật apply, booking và hệ thống</p>
        </div>
        @if (Model.Any(n => !n.IsRead))
        {
            <form asp-action="MarkAllRead" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-secondary btn-sm" type="submit">
                    <i class="bi bi-check2-all me-1"></i> Đọc tất cả
                </button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="surface-card">
            <div class="empty-state">
                <i class="bi bi-bell"></i>
                <p class="mb-0">Chưa có thông báo.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var n in Model)
        {
            <div class="notif-item @(n.IsRead ? "" : "unread")">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div class="min-w-0">
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <strong>@n.Title</strong>
                            @if (!n.IsRead)
                            {
                                <span class="badge badge-soft-primary">Mới</span>
                            }
                        </div>
                        <div class="small">@n.Body</div>
                        <div class="small text-muted mt-1">
                            <span class="badge badge-soft-secondary me-1">@n.Type</span>
                            @n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkRead" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@n.Id" />
                            <button class="btn btn-sm btn-ghost" type="submit" title="Đánh dấu đã đọc">
                                <i class="bi bi-check2"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    }
</div>
