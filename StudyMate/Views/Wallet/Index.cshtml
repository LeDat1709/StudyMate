@model List<StudyMate.Models.WalletTransaction>
@{ ViewData["Title"] = "Ví"; }

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Ví StudyMate</h1>
            <p>Số dư và lịch sử giao dịch (deposit stub)</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-lg-5">
            <div class="wallet-balance h-100">
                <div class="balance-label">Số dư khả dụng</div>
                <div class="balance-value">@(((decimal)ViewData["Balance"]!).ToString("N0")) ₫</div>
                <p class="small mb-0 mt-2" style="opacity:.8">Thanh toán escrow sẽ nối ở phase sau</p>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="surface-card h-100">
                <div class="card-body">
                    <div class="card-section-title">
                        <i class="bi bi-plus-circle text-primary"></i> Nạp tiền (stub)
                    </div>
                    <form asp-action="Deposit" method="post" class="row g-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <div class="col-sm-6">
                            <label class="form-label small">Số tiền (VND)</label>
                            <input name="amount" type="number" class="form-control" value="100000" min="1000" />
                        </div>
                        <div class="col-sm-6">
                            <button class="btn btn-primary w-100" type="submit">
                                <i class="bi bi-wallet2 me-1"></i> Nạp ngay
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="surface-card">
        <div class="card-body">
            <div class="card-section-title">
                <i class="bi bi-receipt text-primary"></i> Lịch sử giao dịch
            </div>
            @if (!Model.Any())
            {
                <div class="empty-state py-4">
                    <i class="bi bi-inbox"></i>
                    <p class="mb-0">Chưa có giao dịch.</p>
                </div>
            }
            else
            {
                <div class="sm-stack">
                    @foreach (var t in Model)
                    {
                        <div class="sm-stack-item">
                            <div>
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <strong>@t.Type</strong>
                                    <span class="badge badge-soft-secondary">@t.Status</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(t.Note))
                                {
                                    <div class="small text-muted">@t.Note</div>
                                }
                            </div>
                            <strong class="text-primary">@t.Amount.ToString("N0") ₫</strong>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
