@model StudyMate.ViewModels.Account.CertificatesPageViewModel
@{
    ViewData["Title"] = "Chứng chỉ";
    var success = ViewData["UploadSuccess"] != null;
    var certTypes = new[] { "Degree", "Certificate", "IELTS", "TOEIC" };
}

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Chứng chỉ gia sư</h1>
            <p>Upload bằng cấp, IELTS, chứng chỉ — chờ hệ thống / admin xác minh</p>
        </div>
        <a asp-action="Profile" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Hồ sơ
        </a>
    </div>

    <div class="cert-layout">
        <div class="surface-card">
            <div class="card-body">
                <div class="card-section-title">
                    <i class="bi bi-cloud-upload text-primary"></i> Upload mới
                </div>

                @if (success)
                {
                    <div class="alert alert-success py-2 small" role="alert">
                        <i class="bi bi-check-circle me-1"></i>
                        Upload thành công. Trạng thái: <strong>Chờ xác minh</strong>.
                    </div>
                }

                <form asp-action="UploadCertificate" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Upload.Title" class="form-label"></label>
                        <input asp-for="Upload.Title" class="form-control" placeholder="VD: IELTS 8.0" />
                        <span asp-validation-for="Upload.Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Upload.CertType" class="form-label"></label>
                        <select asp-for="Upload.CertType" class="form-select">
                            <option value="">-- Chọn loại --</option>
                            @foreach (var t in certTypes)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                        <span asp-validation-for="Upload.CertType" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Upload.IssuedBy" class="form-label"></label>
                        <input asp-for="Upload.IssuedBy" class="form-control" placeholder="Đơn vị cấp" />
                        <span asp-validation-for="Upload.IssuedBy" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Upload.IssuedDate" class="form-label"></label>
                        <input asp-for="Upload.IssuedDate" class="form-control" type="date" />
                        <span asp-validation-for="Upload.IssuedDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Upload.File" class="form-label"></label>
                        <input asp-for="Upload.File" class="form-control" type="file"
                               accept=".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf" />
                        <div class="form-text">JPG, PNG hoặc PDF — tối đa 10MB</div>
                        <span asp-validation-for="Upload.File" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload me-1"></i> Upload chứng chỉ
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="surface-card">
            <div class="card-body p-0">
                <div class="card-body pb-0">
                    <div class="card-section-title mb-0">
                        <i class="bi bi-collection text-primary"></i> Danh sách
                        <span class="badge rounded-pill text-bg-light border ms-1">@Model.Certificates.Count</span>
                    </div>
                </div>

                @if (Model.Certificates.Count == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-folder2-open"></i>
                        <p class="mb-0">Chưa có chứng chỉ nào.<br />Hãy upload file bên trái để bắt đầu.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table cert-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Tên</th>
                                    <th>Loại</th>
                                    <th>Ngày upload</th>
                                    <th>Trạng thái</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Certificates)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@c.Title</div>
                                            @if (!string.IsNullOrEmpty(c.IssuedBy))
                                            {
                                                <div class="small text-muted-soft">@c.IssuedBy</div>
                                            }
                                        </td>
                                        <td><span class="text-muted-soft">@(c.CertType ?? "—")</span></td>
                                        <td class="small text-muted-soft">@c.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @if (c.IsVerified)
                                            {
                                                <span class="badge badge-soft-success">
                                                    <i class="bi bi-patch-check me-1"></i>Đã xác minh
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-soft-warning">
                                                    <i class="bi bi-hourglass-split me-1"></i>Chờ xác minh
                                                </span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (!string.IsNullOrEmpty(c.FileUrl))
                                            {
                                                <a href="@c.FileUrl" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
