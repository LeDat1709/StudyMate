@{
    ViewData["Title"] = "Xác thực email";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-sm-10 col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <h4 class="card-title mb-3">Kiểm tra hộp thư của bạn</h4>
                @if (!string.IsNullOrEmpty(ViewBag.Email as string))
                {
                    <p class="text-muted">
                        Chúng tôi đã gửi mã OTP đến <strong>@ViewBag.Email</strong>.<br />
                        Vui lòng kiểm tra email và nhập mã để xác thực tài khoản.
                    </p>
                }
                else
                {
                    <p class="text-muted">Vui lòng kiểm tra email để lấy mã OTP xác thực.</p>
                }
                <div class="alert alert-info mt-3">
                    ⏳ Trang nhập OTP đang được phát triển (M1-T4)
                </div>
            </div>
        </div>
    </div>
</div>
