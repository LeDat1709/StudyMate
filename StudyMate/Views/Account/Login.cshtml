@model StudyMate.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["FullBleed"] = true;
    var returnUrl = ViewData["ReturnUrl"] as string;
    var showResendLink = ViewData["ShowResendLink"] as bool? ?? false;
}

<div class="auth-shell">
    <div class="auth-grid">
        <aside class="auth-aside">
            <div>
                <span class="auth-aside-badge"><i class="bi bi-mortarboard"></i> StudyMate</span>
                <h2>Chào mừng trở lại</h2>
                <p>Đăng nhập để tiếp tục hành trình học tập hoặc giảng dạy của bạn.</p>
                <ul class="auth-feature-list">
                    <li><i class="bi bi-check-circle-fill"></i> Hồ sơ cá nhân &amp; avatar</li>
                    <li><i class="bi bi-check-circle-fill"></i> Bảo mật OTP &amp; khóa an toàn</li>
                    <li><i class="bi bi-check-circle-fill"></i> Gia sư upload chứng chỉ minh bạch</li>
                </ul>
            </div>
            <p class="small mb-0" style="opacity:.75">Kết nối học viên và gia sư tin cậy.</p>
        </aside>

        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-icon"><i class="bi bi-box-arrow-in-right"></i></div>
                <h1 class="auth-title">Đăng nhập</h1>
                <p>Nhập email và mật khẩu của bạn</p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                @if (showResendLink)
                {
                    <div class="alert alert-warning py-2 small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Email chưa được xác thực.
                        <a asp-action="VerifyEmail" class="fw-semibold">Xác thực ngay</a>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control border-start-0" placeholder="you@email.com" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" class="form-control border-start-0" placeholder="Mật khẩu" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                    <a asp-action="ForgotPassword" class="small fw-semibold">Quên mật khẩu?</a>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Đăng nhập</button>
                </div>
            </form>

            <div class="auth-footer-links">
                Chưa có tài khoản?
                <a asp-action="Register" class="fw-semibold">Đăng ký ngay</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
