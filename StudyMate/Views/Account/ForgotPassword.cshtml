@model StudyMate.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    ViewData["FullBleed"] = true;
}

<div class="auth-shell">
    <div class="auth-card auth-card-narrow">
        <div class="auth-card-header">
            <div class="auth-icon"><i class="bi bi-key"></i></div>
            <h1 class="auth-title">Quên mật khẩu</h1>
            <p>Nhập email đã đăng ký. Chúng tôi sẽ gửi mã OTP để đặt lại mật khẩu.</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="you@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Gửi mã OTP</button>
            </div>
        </form>

        <div class="auth-footer-links">
            <a asp-action="Login"><i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
