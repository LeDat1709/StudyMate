@model StudyMate.Controllers.BookingFormVm
@{ ViewData["Title"]="Tạo booking"; }
<div class="page-shell"><div class="surface-card"><div class="card-body">
  <h1 class="h5">Tạo lịch — @ViewData["JobTitle"]</h1>
  <form asp-action="Create" method="post">@Html.AntiForgeryToken()
    <input type="hidden" asp-for="ApplicationId"/>
    <div class="mb-3"><label asp-for="ScheduledStart" class="form-label"></label><input asp-for="ScheduledStart" class="form-control" type="datetime-local"/></div>
    <div class="mb-3"><label asp-for="ScheduledEnd" class="form-label"></label><input asp-for="ScheduledEnd" class="form-control" type="datetime-local"/><span asp-validation-for="ScheduledEnd" class="text-danger small"></span></div>
    <div class="mb-3"><label asp-for="MeetingUrl" class="form-label"></label><input asp-for="MeetingUrl" class="form-control"/></div>
    <div class="mb-3"><label asp-for="Note" class="form-label"></label><textarea asp-for="Note" class="form-control"></textarea></div>
    <button class="btn btn-primary">Tạo</button>
  </form>
</div></div></div>
