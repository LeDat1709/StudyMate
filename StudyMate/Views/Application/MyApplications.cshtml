@model List<StudyMate.Models.JobApplication>
@{
    ViewData["Title"] = "Apply của tôi";
    string StatusBadge(string s) => s switch
    {
        "Pending" => "badge-soft-warning",
        "Accepted" => "badge-soft-success",
        "Rejected" => "badge-soft-danger",
        "Cancelled" => "badge-soft-secondary",
        _ => "badge-soft-primary"
    };
}

<div class="page-shell">
    <div class="page-header">
        <div>
            <h1>Proposals của tôi</h1>
            <p>Theo dõi apply đã gửi — giống My Proposals trên marketplace</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="JobPosting" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-briefcase me-1"></i> Tìm việc
            </a>
            <a asp-controller="Matching" asp-action="RecommendedJobs" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-stars me-1"></i> Job gợi ý
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="surface-card">
            <div class="empty-state">
                <i class="bi bi-send"></i>
                <p class="mb-2">Bạn chưa gửi apply nào.</p>
                <a asp-controller="JobPosting" asp-action="Index" class="btn btn-primary btn-sm">Duyệt job mở</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var a in Model)
        {
            <div class="proposal-item">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                    <div class="min-w-0">
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <a asp-controller="JobPosting" asp-action="Details" asp-route-id="@a.JobPostingId"
                               class="tutor-name text-decoration-none">
                                @(a.JobPosting?.Title ?? $"Job #{a.JobPostingId}")
                            </a>
                            <span class="badge @StatusBadge(a.Status)">@a.Status</span>
                        </div>
                        <div class="small text-muted">
                            Gửi @a.AppliedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            @if (a.JobPosting?.Subject != null)
                            {
                                <span>· @a.JobPosting.Subject.Name</span>
                            }
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="proposed-rate">@(a.ProposedRate?.ToString("N0") ?? "—") ₫</div>
                        <div class="small text-muted">đề xuất / giờ</div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(a.CoverNote))
                {
                    <div class="cover-note text-truncate" style="max-width:100%">@a.CoverNote</div>
                }

                @if (a.Status == "Pending")
                {
                    <div class="mt-2">
                        <form asp-action="Cancel" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@a.Id" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Rút apply</button>
                        </form>
                    </div>
                }
            </div>
        }
    }
</div>
